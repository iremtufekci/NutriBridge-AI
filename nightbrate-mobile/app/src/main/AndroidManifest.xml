<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.nightbrate">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".NightstrateApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nightbrate"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Nightbrate.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".RegisterClientActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".RegisterDietitianActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".AdminDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".DietitianDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".ClientDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".ClientProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".ClientDietProgramActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".ClientDietProgramHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".DietitianProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".DietitianProgramsActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".AdminSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".AdminDietitianApprovalsActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".ClientPlaceholderActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".DietitianPlaceholderActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".AdminPlaceholderActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".AdminSystemAnalyticsActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

        <activity
            android:name=".AdminUserManagementActivity"
            android:exported="false"
            android:theme="@style/Theme.Nightbrate.NoActionBar" />

    </application>
</manifest>