<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/admin_card_bg"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/admin_row_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/apAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/um_avatar_circle"
                android:gravity="center"
                android:text="D"
                android:textColor="@color/um_avatar_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/apName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:textColor="@color/admin_strong"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/apEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/admin_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/apDiploma"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/admin_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/apClinic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/admin_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/apDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/admin_muted"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/um_chip_status_pending"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Beklemede"
            android:textColor="@color/um_chip_amber_text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/apInspect"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="İncele"
                android:textAllCaps="false"
                app:cornerRadius="20dp"
                app:strokeColor="@color/admin_row_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/apApprove"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:minWidth="0dp"
                android:text="Onayla"
                android:textAllCaps="false"
                app:backgroundTint="@color/brand"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/apReject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:enabled="false"
                android:minWidth="0dp"
                android:text="Reddet"
                android:textAllCaps="false"
                app:backgroundTint="@color/admin_row_stroke"
                app:cornerRadius="20dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
