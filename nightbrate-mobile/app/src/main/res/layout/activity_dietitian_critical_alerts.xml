<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_page_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kritik uyarılar"
                android:textColor="@color/admin_strong"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Son 3 gün verisine göre öğün uyumu ve günlük kalori kuralları değerlendirilir. İncelediğiniz kayıt listeden düşer; eşikler yeniden aşılırsa yeni uyarı oluşabilir."
                android:textColor="@color/admin_muted"
                android:textSize="14sp" />

            <ProgressBar
                android:id="@+id/progressCriticalAlerts"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvCriticalAlertsError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:textColor="#B91C1C"
                android:textSize="14sp"
                android:visibility="gone" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCriticalAlertsBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF1F2"
                app:cardCornerRadius="16dp"
                app:strokeColor="#FECDD3"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tvCriticalAlertsBannerText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textColor="#9F1239"
                    android:textSize="14sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCriticalAlertsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#ECFDF5"
                app:cardCornerRadius="16dp"
                app:strokeColor="#A7F3D0"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="20dp"
                    android:text="Şu an listelenecek kritik uyarı yok.\nYeni kayıtlar veri geldikçe burada belirir."
                    android:textColor="#065F46"
                    android:textSize="14sp" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/llCriticalAlertsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/include_dietitian_bottom_bar" />
</LinearLayout>
