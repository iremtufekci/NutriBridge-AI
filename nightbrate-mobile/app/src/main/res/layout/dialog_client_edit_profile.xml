<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Ad"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/dlgEtFirst"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ad"
            android:inputType="textPersonName" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:text="Soyad"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/dlgEtLast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Soyad"
            android:inputType="textPersonName" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:text="Boy (cm)"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/dlgEtHeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="170"
            android:inputType="numberDecimal" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:text="Kilo (kg)"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/dlgEtWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="70"
            android:inputType="numberDecimal" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:text="Günlük hedef kalori"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/dlgEtCal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="2000"
            android:inputType="number" />

        <TextView
            android:id="@+id/tvDlgGoalHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnDlgPreset1600"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/custom_input_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:padding="10dp"
                android:text="Kilo ver (1600)"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btnDlgPreset2000"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/custom_input_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:padding="10dp"
                android:text="Formu koru (2000)"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btnDlgPreset2500"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/custom_input_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:padding="10dp"
                android:text="Kilo al (2500)"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
