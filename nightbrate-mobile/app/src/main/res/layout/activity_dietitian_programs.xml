<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Diyet programi"
                android:textColor="@color/primary_green"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Listeden arayip secin; secili isim burada gorunur."
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDietSelectedClient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/custom_input_bg"
                android:backgroundTint="#14532D"
                android:padding="12dp"
                android:text="Secili danisan: —\nArayip listeden secin"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/etDietClientSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/custom_input_bg"
                android:hint="Danisan adi ile ara"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_gray" />

            <ListView
                android:id="@+id/lvDietClients"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/custom_input_bg"
                android:divider="@color/text_gray"
                android:dividerHeight="1px" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Bu danisana atadiginiz tarihler (duzenleme) — yatay kaydirin"
                android:textColor="@color/primary_green"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/dietAssignedRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Tarih: onumuzdeki 60 gun (yeni) veya yukaridan atadiginiz gun"
                android:textColor="@color/text_gray"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/dietDayRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kahvalti"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="kcal"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etDietBreakfastKcal"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/custom_input_bg"
                    android:gravity="end|center_vertical"
                    android:hint="0"
                    android:inputType="number"
                    android:padding="8dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_gray"
                    android:textSize="14sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/etDietBreakfast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/custom_input_bg"
                android:gravity="top|start"
                android:hint="Kahvalti notu"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:padding="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_gray" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ogle"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="kcal"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etDietLunchKcal"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/custom_input_bg"
                    android:gravity="end|center_vertical"
                    android:hint="0"
                    android:inputType="number"
                    android:padding="8dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_gray"
                    android:textSize="14sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/etDietLunch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/custom_input_bg"
                android:gravity="top|start"
                android:hint="Ogle notu"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:padding="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_gray" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Aksam"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="kcal"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etDietDinnerKcal"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/custom_input_bg"
                    android:gravity="end|center_vertical"
                    android:hint="0"
                    android:inputType="number"
                    android:padding="8dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_gray"
                    android:textSize="14sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/etDietDinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/custom_input_bg"
                android:gravity="top|start"
                android:hint="Aksam notu"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:padding="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_gray" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ara ogun"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="kcal"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etDietSnackKcal"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/custom_input_bg"
                    android:gravity="end|center_vertical"
                    android:hint="0"
                    android:inputType="number"
                    android:padding="8dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_gray"
                    android:textSize="14sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/etDietSnack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/custom_input_bg"
                android:gravity="top|start"
                android:hint="Ara ogun notu"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2"
                android:padding="12dp"
                android:textColor="@color/white"
                android:textColorHint="@color/text_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Gunluk toplam (ogun toplamı, otomatik)"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDietTotalKcal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/custom_input_bg"
                android:padding="12dp"
                android:text="0 kcal"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnDietSaveProgram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary_green"
                android:text="Programi kaydet"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_dietitian_bottom_bar" />
</LinearLayout>
