<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/nav_bar_bg"
    android:elevation="10dp"
    android:gravity="center"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/tabHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/iconHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌂"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/labelHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Ana Sayfa"
            android:textColor="@color/nav_item_inactive"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabJournal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/iconJournal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/labelJournal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Diyet Programım"
            android:textColor="@color/nav_item_inactive"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabFood"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/iconFood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/labelFood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Yemek Analizi"
            android:textColor="@color/nav_item_inactive"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabChef"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/iconChef"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍳"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/labelChef"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="AI Mutfak"
            android:textColor="@color/nav_item_inactive"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/iconProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/labelProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Profilim"
            android:textColor="@color/nav_item_inactive"
            android:textSize="9sp" />
    </LinearLayout>
</LinearLayout>
