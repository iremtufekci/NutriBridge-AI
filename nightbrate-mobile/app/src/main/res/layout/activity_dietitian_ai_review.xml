<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_page_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yapay zeka denetimi"
                android:textColor="@color/admin_strong"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Bilgi: Danışanların yapay zeka mutfak ekranında seçtikleri ve sizinle paylaştıkları tarifler listelenir. Kayıtlar yalnızca sizin danışanlarınız içindir."
                android:textColor="@color/admin_muted"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAiReviewSelected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#DFF1EA"
                app:cardCornerRadius="16dp"
                app:strokeColor="#CCE6DC"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SEÇİLİ DANIŞAN"
                        android:textColor="#047857"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAiReviewSelectedName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/admin_strong"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/admin_card_bg"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/admin_row_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <EditText
                        android:id="@+id/etAiReviewSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Danışan adı ile ara…"
                        android:importantForAutofill="no"
                        android:inputType="text"
                        android:padding="12dp" />

                    <ProgressBar
                        android:id="@+id/progressAiReviewClients"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp" />

                    <ListView
                        android:id="@+id/listAiReviewClients"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:divider="@color/admin_row_stroke"
                        android:dividerHeight="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutAiReviewKitchenSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/admin_card_bg"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/admin_row_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvAiReviewLogsSectionTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Yapay zeka mutfak paylaşımları"
                            android:textColor="@color/admin_strong"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Danışan uygulamada seçer ve paylaşır; burada sadece okunur. Son kayıtlar (en çok 30) listelenir."
                            android:textColor="@color/admin_muted"
                            android:textSize="13sp" />

                        <ProgressBar
                            android:id="@+id/progressAiReviewKitchen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvAiReviewLogsEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Henüz paylaşılmış tarif yok veya yükleme hatası."
                            android:textColor="@color/admin_muted"
                            android:textSize="13sp"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/llAiReviewKitchenLogs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/include_dietitian_bottom_bar" />
</LinearLayout>
