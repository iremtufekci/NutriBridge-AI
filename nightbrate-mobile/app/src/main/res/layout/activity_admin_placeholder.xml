<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_page_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Admin"
                android:textColor="@color/primary_green"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/aPlaceholderTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Baslik"
                android:textColor="@color/admin_strong"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/aPlaceholderMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="3dp"
                android:text="Aciklama"
                android:textColor="@color/text_gray"
                android:textSize="15sp" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_admin_bottom_bar" />
</LinearLayout>
