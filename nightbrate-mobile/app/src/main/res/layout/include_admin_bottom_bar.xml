<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="10dp"
    android:gravity="center"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/atab0"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/aicon0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▣"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/alabel0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Özet"
            android:textColor="@color/nav_item_inactive"
            android:textSize="8sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/atab1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/aicon1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/alabel1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Kullanıcılar"
            android:textColor="@color/nav_item_inactive"
            android:textSize="8sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/atab2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/aicon2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/alabel2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Onaylar"
            android:textColor="@color/nav_item_inactive"
            android:textSize="8sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/atab3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/aicon3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📈"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/alabel3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Analitik"
            android:textColor="@color/nav_item_inactive"
            android:textSize="8sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/atab4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/aicon4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/alabel4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Ayarlar"
            android:textColor="@color/nav_item_inactive"
            android:textSize="8sp" />
    </LinearLayout>
</LinearLayout>
