<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="10dp"
    android:fillViewport="true"
    android:paddingTop="6dp"
    android:paddingBottom="8dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp">

        <LinearLayout
            android:id="@+id/dtab0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="64dp"
            android:orientation="vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/dicon0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▣"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/dlabel0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="Panel"
                android:textColor="@color/nav_item_inactive"
                android:textSize="8sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dtab1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="64dp"
            android:orientation="vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/dicon1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/dlabel1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="Danışanlar"
                android:textColor="@color/nav_item_inactive"
                android:textSize="8sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dtab2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="64dp"
            android:orientation="vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/dicon2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/dlabel2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="Programlar"
                android:textColor="@color/nav_item_inactive"
                android:textSize="8sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dtab3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="64dp"
            android:orientation="vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/dicon3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/dlabel3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="YZ denetim"
                android:textColor="@color/nav_item_inactive"
                android:textSize="8sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dtab4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="64dp"
            android:orientation="vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/dicon4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/dlabel4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="Uyarılar"
                android:textColor="@color/nav_item_inactive"
                android:textSize="8sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dtab5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="64dp"
            android:orientation="vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/dicon5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/dlabel5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:text="Profil"
                android:textColor="@color/nav_item_inactive"
                android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>
</HorizontalScrollView>
