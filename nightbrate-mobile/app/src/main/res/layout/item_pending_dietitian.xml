<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/admin_card_bg"
    app:cardCornerRadius="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/pdName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ad Soyad"
            android:textColor="@color/admin_strong"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pdEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="E-posta"
            android:textColor="@color/text_gray"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/pdDiploma"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Diploma"
            android:textColor="@color/admin_strong"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/pdClinic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Klinik"
            android:textColor="@color/admin_strong"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/pdStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#3D2E08"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Onaylanmadı"
            android:textColor="#FBBF24"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/pdApprove"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/primary_green"
            android:text="Onayla (veritabanında onaylandı)"
            android:textColor="@color/white" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
